NODE_ENV=development
LOG_LEVEL=debug
SERVICE_PUBLIC_PORT=8080
AUTH_SERVICE_PORT=8080
AUTH_GATEWAY_IN_DOCKER=1

# Postgres Configuration
POSTGRES_USER=rsl_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=rsldb
POSTGRES_DB_TEST=rsldb_test

# Local development overrides (outside of docker) connecting to dockerized infra
DATABASE_URL=postgresql://rsl_user:your_postgres_password_here@rsldb:5432/rsldb
TEST_DATABASE_URL=postgresql://rsl_user:your_postgres_password_here@rsldb-test:5432/rsldb_test
DATABASE_URL_READ_REPLICA=postgresql://rsl_user:your_postgres_password_here@rsldb-read:5432/rsldb
REDIS_URL=redis://redis-dev:6379

# Unified Backend Port mapping
PORT=8080

JWT_PRIVATE_KEY=your_jwt_private_key_here
JWT_PUBLIC_KEY=your_jwt_public_key_here
INTERNAL_SERVICE_KEY=your_internal_service_key_here
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d
DB_POOL_MIN=2
DB_POOL_MAX=10

# eBay API Configuration
# Switch between sandbox and production by changing EBAY_ENV
EBAY_ENV=sandbox
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_DEV_ID=your_ebay_dev_id_here

# Sandbox credentials (developer.ebay.com → Sandbox Keys)
EBAY_SANDBOX_CLIENT_ID=your_ebay_sandbox_client_id_here
EBAY_SANDBOX_CLIENT_SECRET=your_ebay_sandbox_client_secret_here
EBAY_SANDBOX_API_URL=https://api.sandbox.ebay.com
EBAY_SANDBOX_TOKEN_URL=https://api.sandbox.ebay.com/identity/v1/oauth2/token
EBAY_SANDBOX_AUTH_URL=https://auth.sandbox.ebay.com/oauth2/authorize
EBAY_SANDBOX_RU_NAME=your_ebay_sandbox_ru_name_here

# Production credentials (developer.ebay.com → Production Keys)
EBAY_PROD_CLIENT_ID=your_ebay_prod_client_id_here
EBAY_PROD_CLIENT_SECRET=your_ebay_prod_client_secret_here
EBAY_PROD_API_URL=https://api.ebay.com
EBAY_PROD_TOKEN_URL=https://api.ebay.com/identity/v1/oauth2/token
EBAY_PROD_AUTH_URL=https://auth.ebay.com/oauth2/authorize
EBAY_PROD_RU_NAME=your_ebay_prod_ru_name_here

# Google Vertex AI & OpenRouter
VERTEX_AI_PROJECT_ID=your_vertex_ai_project_id_here
VERTEX_AI_LOCATION=us-central1
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google & Apple OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
APPLE_AUDIENCE=com.rslcards.dealer
APPLE_ISSUER=https://appleid.apple.com

# AWS S3 — Card image + profile pic storage
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=eu-north-1
S3_BUCKET_NAME=your_s3_bucket_name_here

# Ximilar AI Card Scanning API
XIMILAR_API_KEY=your_ximilar_api_key_here
SOLD_COMPS_KEY=your_sold_comps_key_here

# MySlabs API Keys
MYSLABS_CLIENT_ID=your_myslabs_client_id_here
MYSLABS_CLIENT_SECRET=your_myslabs_client_secret_here
