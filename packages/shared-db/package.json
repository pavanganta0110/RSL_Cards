{
  "name": "@rsl/shared-db",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "generate:dev": "bun x drizzle-kit generate --config drizzle.dev.config.ts",
    "generate:qa": "bun x drizzle-kit generate --config drizzle.qa.config.ts",
    "generate:prod": "bun x drizzle-kit generate --config drizzle.prod.config.ts",
    "generate:test": "bun x drizzle-kit generate --config drizzle.test.config.ts",
    "migrate:dev": "bun x drizzle-kit migrate --config drizzle.dev.config.ts",
    "migrate:qa": "bun x drizzle-kit migrate --config drizzle.qa.config.ts",
    "migrate:prod": "bun x drizzle-kit migrate --config drizzle.prod.config.ts",
    "migrate:test": "bun x drizzle-kit migrate --config drizzle.test.config.ts",
    "seed:dev": "tsx src/seed.ts",
    "studio": "bun x drizzle-kit studio --config drizzle.dev.config.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
